# =============================================================
# AdVirus Evolution Lab - Environment Variables Template
# =============================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to Git!
# =============================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"

# --- Monetag Ad SDK ---
NEXT_PUBLIC_MONETAG_ZONE_ID="your_zone_id"
NEXT_PUBLIC_MONETAG_AUCTION_KEY="your_auction_key"

# --- MongoDB (Atlas) ---
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/advirus?retryWrites=true&w=majority"

# --- Redis (Upstash / ElastiCache) ---
REDIS_URL="redis://default:password@your-redis-host:6379"

# --- Security ---
JWT_SECRET="replace_with_64_char_random_hex_string"
PAYLOAD_SIGNING_KEY="replace_with_another_64_char_random_hex_string"

# --- Analytics (PostHog) ---
NEXT_PUBLIC_POSTHOG_KEY="phc_your_posthog_project_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# --- Feature Flags (Optional - Remote Config) ---
SYNERGY_BASE_MULTIPLIER="1.0"
ENERGY_REFILL_HOURS="2"
MAX_ENERGY="10"
